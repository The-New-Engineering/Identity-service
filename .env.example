# ── Bucket 1: Platform ────────────────────────────────────────────────────────
SERVICE_NAME=identity-service
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ── Bucket 2: Infrastructure ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/identity
DATABASE_POOL_MAX=10
REDIS_URL=redis://localhost:6379

# ── Bucket 3: JWT ─────────────────────────────────────────────────────────────
# Generate with: openssl genrsa -out private.pem 2048
#                openssl rsa -in private.pem -pubout -out public.pem
# Replace newlines with \n when setting here
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_EXPIRY=900
REFRESH_TOKEN_EXPIRY=604800

# ── Bucket 4: Token TTLs ──────────────────────────────────────────────────────
MIGRATION_TOKEN_TTL=900
RESET_TOKEN_TTL=3600

# ── Bucket 5: SMTP ────────────────────────────────────────────────────────────
ADMIN_EMAIL=korneliosyaovi@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourorg.com

# ── Bucket 6: OAuth providers ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ── Bucket 7: URLs ────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# ── Bucket 8: Internal service keys ──────────────────────────────────────────
# Shared secret between identity service and member service.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MEMBER_SERVICE_API_KEY=

# ── Bucket 9: Observability ──────────────────────────────────────────────────
# Better Stack source token — WARN and ERROR logs shipped here in production
# Leave empty in development
BETTERSTACK_SOURCE_TOKEN=