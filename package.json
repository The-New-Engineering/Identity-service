{
  "name": "identity-service",
  "version": "1.0.0",
  "description": "Central identity and access management service",
  "main": "dist/server.js",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "validate:contract": "tsx scripts/validate-contract.ts",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^9.3.1",
    "@fastify/env": "^4.4.0",
    "@fastify/helmet": "^11.1.1",
    "@logtail/pino": "^0.5.8",
    "arctic": "^1.9.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.0",
    "fastify": "^4.28.0",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.14",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.15",
    "js-yaml": "^4.1.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5"
  }
